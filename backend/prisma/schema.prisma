datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String           @id
  email         String           @unique
  name          String
  admissionYear Int
  discipline    String
  pursuingHonors Boolean  @default(false)
  pursuingMinor  String?  // Nullable, e.g., "Artificial Intelligence", "Management"
  createdAt     DateTime         @default(now())
  records       AcademicRecord[]
  isAdmin       Boolean          @default(false)
}

model Course {
  id        String   @id @default(uuid())
  code      String   @unique
  title     String
  credits   Int
  branches  String[] // Array of strings (e.g., ["AI", "EE"])
  
  // A course belongs to exactly one basket
  basketId  Int
  basket    Basket   @relation(fields: [basketId], references: [id])
  
  records   AcademicRecord[]
}

model Basket {
  id      Int      @id @default(autoincrement())
  name    String   @unique // e.g., "Humanities", "Science"
  courses Course[] // One basket has many courses
}


model CurriculumRequirement {
  id              Int    @id @default(autoincrement())
  admissionYear   Int
  discipline      String
  basketName      String
  requiredCredits Int

  @@unique([admissionYear, discipline, basketName])
}

model AcademicRecord {
  id        Int     @id @default(autoincrement())
  userId    String
  courseId  String
  semester  Int
  grade     String?
  status    String  // "COMPLETED" or "PLANNED"
  isHonors  Boolean @default(false)
  isMinor   Boolean @default(false)
  isGraded  Boolean @default(true)
  user      User    @relation(fields: [userId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}